// filepath: /Users/minkuu/Documents/krishna project /Textile-Pattern-Defect-Detection-System/frontend/firebase.rules

rules_version = '2';

// Firestore rules: users access own records, admins access all records.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      // Needed so app can verify whether the current user is admin
      allow read: if signedIn() && request.auth.uid == uid;
      // Keep admin membership managed manually (console/backend), not by clients
      allow write: if false;
    }

    match /scans/{scanId} {
      allow read: if signedIn() && (resource.data.owner == request.auth.uid || isAdminUser());
      allow create: if signedIn() && (request.resource.data.owner == request.auth.uid || isAdminUser());
      allow update, delete: if signedIn() && (resource.data.owner == request.auth.uid || isAdminUser());
    }
  }
}

// Storage rules: users access own images, admins access all scan images.
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdminUser() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data != null;
    }

    match /scans/{userId}/{allPaths=**} {
      allow read, write: if signedIn() && (request.auth.uid == userId || isAdminUser());
    }
  }
}
