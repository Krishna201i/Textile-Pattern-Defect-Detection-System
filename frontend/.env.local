# Local development environment variables for TextileGuard frontend
# Copy this file to .env.local and fill in your values.

# Backend API URL (leave empty to use Vite's dev proxy at /api → localhost:5000)
VITE_API_URL=

# Comma-separated list of admin email addresses (fallback if Firestore admins collection is unavailable)
# Example: VITE_ADMIN_EMAILS=admin@example.com,another@example.com
VITE_ADMIN_EMAILS=ks7599020645@gmail.com
