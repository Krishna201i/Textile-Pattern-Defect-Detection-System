// filepath: /Users/minkuu/Documents/krishna project /Textile-Pattern-Defect-Detection-System/frontend/firebase.rules

// Firestore rules: allow authenticated users to read/write their own scans
service cloud.firestore {
  match /databases/{database}/documents {
    match /scans/{scanId} {
      allow read: if request.auth != null && resource.data.owner == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.owner == request.auth.uid;
      allow delete, update: if request.auth != null && resource.data.owner == request.auth.uid;
    }
  }
}

// Storage rules: allow authenticated users to access their scan images under /scans/{uid}/{id}.jpg
service firebase.storage {
  match /b/{bucket}/o {
    match /scans/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // For simple dev setups you may instead allow read for all images:
    // match /scans/{allPaths=**} { allow read: if true; allow write: if request.auth != null; }
  }
}
